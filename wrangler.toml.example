name = "mines-telegram-worker"
main = "worker.js"
compatibility_date = "2026-06-17"

# Создайте Cloudflare D1 Database и подставьте database_id.
# В интерфейсе Cloudflare: Workers & Pages → D1 SQL Database → Create database
[[d1_databases]]
binding = "DB"
database_name = "mines_db"
database_id = "PUT_YOUR_D1_DATABASE_ID_HERE"

# Переменные лучше задать в Cloudflare Dashboard → Worker → Settings → Variables.
# PARTNER_URL = "https://partner-site.example"
# ADMIN_IDS = "123456789,987654321"
# TELEGRAM_BOT_TOKEN = "123:ABC"
# SETUP_SECRET = "any-long-random-string"
